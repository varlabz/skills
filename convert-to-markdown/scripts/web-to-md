#!/usr/bin/env -S uvx --with httpx --with markitdown python
"""Fetch a web page and convert it to Markdown via a Crawl4AI server.

Uses the /crawl endpoint to get the full, untruncated raw
HTML, then converts it to Markdown using markitdown.
"""

import argparse
import asyncio
import os
import sys
from io import BytesIO
from pathlib import Path

import httpx
import markitdown

BASE = "http://localhost:11235"


async def fetch_raw_html(url, server):
    """Crawl a URL via /crawl and return the full raw HTML."""
    async with httpx.AsyncClient(base_url=server, timeout=120.0) as c:
        r = await c.get("/health", timeout=10.0)
        r.raise_for_status()
        r = await c.post(
            "/crawl",
            json={
                "urls": [url],
                "crawler_config": {
                    "word_count_threshold": 1,  # don't truncate
                    "only_text": False,  # keep links/images
                    "remove_overlay_elements": False,
                },
            },
            timeout=120.0,
        )
        r.raise_for_status()
        d = r.json()
        if not d.get("success"):
            raise RuntimeError(f"Server error: {d.get('detail', d)}")
        results = d.get("results", [])
        if not results:
            raise RuntimeError(f"No results returned for URL: {url}")
        item = results[0]
        if not item.get("success"):
            raise RuntimeError(
                f"Crawl failed for {url}: {item.get('error_message', 'unknown error')}"
            )
        html = item.get("html", "")
        if not html:
            raise RuntimeError(f"No HTML content returned for URL: {url}")
        return html


def html_to_markdown(raw_html):
    """Convert raw HTML to Markdown using markitdown."""
    mi = markitdown.MarkItDown()
    result = mi.convert_stream(BytesIO(raw_html.encode()))
    return str(result.text_content) if result else ""


async def fetch(url, server):
    raw_html = await fetch_raw_html(url, server)
    return html_to_markdown(raw_html)


def main():
    p = argparse.ArgumentParser(
        description="Fetch a web page and convert it to Markdown."
    )
    p.add_argument("url")
    p.add_argument(
        "-s",
        "--server",
        default=os.getenv("CRAWL4AI_URL", BASE),
        help=f"Server URL (default: {BASE}, or $CRAWL4AI_URL)",
    )
    p.add_argument(
        "-o",
        "--output",
        metavar="FILE",
        help="Write markdown to FILE instead of stdout",
    )
    args = p.parse_args()
    md = asyncio.run(fetch(args.url, args.server))
    if args.output:
        Path(args.output).write_text(md, encoding="utf-8")
        print(f"Markdown saved to {args.output}", file=sys.stderr)
    else:
        print(md)


if __name__ == "__main__":
    main()
