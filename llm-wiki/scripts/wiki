#!/usr/bin/env bash
#
# wiki - Wrapper script for llm-wiki CLI tool.
#
# Resolves a vault path from .llm-wiki config and invokes llm-wiki with
# the --vault flag. Supports optional --id parameter to select a vault by
# its config variable name. If only one vault is configured, --id is optional.
#
# Usage: wiki [--id wiki-id] <command> [args...]
#
set -eu

# Resolve .llm-wiki config location.
# Priority: LLM_WIKI_CONFIG env var > default path (4 levels up from script).
resolve_config() {
    if [ -n "${LLM_WIKI_CONFIG:-}" ] && [ -f "$LLM_WIKI_CONFIG" ]; then
        echo "$LLM_WIKI_CONFIG"
    else
        local default="$(dirname "$0")/../../../../.llm-wiki"
        if [ -f "$default" ]; then
            echo "$default"
        else
            echo "Error: No .llm-wiki config found (checked LLM_WIKI_CONFIG=$LLM_WIKI_CONFIG and default $default)" >&2
            exit 1
        fi
    fi
}

[ $# -ge 1 ] || { echo "Usage: wiki [--id wiki-id] <command> [args...]"; exit 1; }

CONFIG_FILE="$(resolve_config)"

#use --id id if provided, otherwise default if only one variable in config
ID=""
while [[ $# -ge 1 ]]; do
    if [[ "$1" == --id ]] && [[ $# -ge 2 ]]; then
        ID="$2"; shift 2
    else
        break
    fi
done

# Regex pattern for matching shell variable assignments (allows optional whitespace before =)
VAR_RE='^([a-zA-Z_][a-zA-Z0-9_]*)[[:space:]]*='

if [ -n "$ID" ]; then
    VAULT_PATH=$( ( source "$CONFIG_FILE"; echo "${!ID:-}" ) )
    [ -n "$VAULT_PATH" ] && [ -d "$VAULT_PATH" ] || { echo "Error: Id '$ID' not found or vault '$VAULT_PATH' missing"; exit 1; }
else
    VAR_COUNT=0
    while IFS= read -r line || [[ -n "$line" ]]; do
        [[ "$line" =~ $VAR_RE ]] && VAR_COUNT=$((VAR_COUNT + 1))
    done < "$CONFIG_FILE"
    if [ "$VAR_COUNT" -eq 1 ]; then
        VAR_NAME=$(while IFS= read -r line || [[ -n "$line" ]]; do [[ "$line" =~ $VAR_RE ]] && echo "${BASH_REMATCH[1]}" && break; done < "$CONFIG_FILE")
        VAULT_PATH=$( ( source "$CONFIG_FILE"; echo "${!VAR_NAME:-}" ) )
    elif [ "$VAR_COUNT" -eq 0 ]; then
        echo "Error: No vaults configured in '$CONFIG_FILE'"
        exit 1
    else
        echo "Error: Provide --id (e.g. --id wiki) — $VAR_COUNT vaults configured"
        exit 1
    fi
fi

[ -n "$VAULT_PATH" ] && [ -d "$VAULT_PATH" ] || { echo "Error: No vault resolved '$VAULT_PATH'"; exit 1; }

uvx --from git+https://github.com/Electro-resonance/LLM-WIKI-MCP/ --with mcp llm-wiki --vault "$VAULT_PATH" "$@"
